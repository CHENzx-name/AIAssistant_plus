<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="模型设置">

        <EditTextPreference
            app:key="key_model_name"
            app:title="模型名称"
            app:defaultValue="deepseek/deepseek-v3.2-251201"
            app:useSimpleSummaryProvider="true" />

    </PreferenceCategory>
    <PreferenceCategory app:title="API设置">

        <EditTextPreference
            app:key="key_api_key"
            app:title="API Key"
            app:summary="设置您的百炼API Key"
            app:defaultValue="sk-a7ba8fe3a916194260b9765228b4c0a68281509b424a83e4274e6b517d4ff03e"
            app:useSimpleSummaryProvider="true" />

    </PreferenceCategory>

    <PreferenceCategory app:title="语音输入">

        <ListPreference
            app:key="key_mic_mode"
            app:title="语音按钮行为"
            app:defaultValue="fill"
            app:entries="@array/mic_mode_entries"
            app:entryValues="@array/mic_mode_values"
            app:useSimpleSummaryProvider="true" />

    </PreferenceCategory>

    <PreferenceCategory app:title="说明书管理">

        <Preference
            app:key="key_manuals"
            app:title="查看说明书"
            app:summary="管理和查看已创建的应用说明书" />

    </PreferenceCategory>
</PreferenceScreen>
